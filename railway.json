{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "RAILPACK",
    "watchPatterns": [
      "package.json",
      "package-lock.json",
      "storage.js",
      "extension/**",
      "extension-backend/**"
    ]
  },
  "deploy": {
    "startCommand": "npm run start:railway",
    "healthcheckPath": "/health",
    "healthcheckTimeout": 120,
    "restartPolicyType": "ALWAYS"
  }
}
