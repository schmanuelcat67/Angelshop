# Extension Backend Environment Variables

# Server Port
EXT_BACKEND_PORT=3001

# Twitch Extension Secret (get this from dev.twitch.tv console)
TWITCH_EXT_SECRET=your-extension-signing-secret

# Environment
NODE_ENV=development

# Optional: API Keys for future features
# SOUNDALERTS_API_KEY=your-soundalerts-api-key
# YOUTUBE_API_KEY=your-youtube-api-key
